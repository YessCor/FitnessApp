generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Tabla de Usuarios
model Usuario {
  id            Int           @id @default(autoincrement())
  nombre        String        @map("nombre") @db.VarChar(100)
  apellido      String        @map("apellido") @db.VarChar(100)
  email         String        @unique @db.VarChar(255)
  username      String        @unique @db.VarChar(50)
  passwordHash  String        @map("password_hash") @db.VarChar(255)
  fechaNacimiento DateTime?   @map("fecha_nacimiento") @db.Date
  rol           String        @default("usuario") @db.VarChar(20)
  createdAt     DateTime      @default(now()) @map("created_at")

  perfilFisico  PerfilFisico?
  progresos     Progreso[]

  @@map("usuarios")
}

// Tabla de Perfil Físico
model PerfilFisico {
  id          Int       @id @default(autoincrement())
  usuarioId   Int       @unique @map("usuario_id")
  peso        Decimal   @db.Decimal(5, 2)
  estatura    Decimal?  @db.Decimal(3, 2)
  createdAt   DateTime  @default(now()) @map("created_at")

  usuario     Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("perfil_fisico")
}

// Tabla de Progreso
model Progreso {
  id          Int       @id @default(autoincrement())
  usuarioId   Int       @map("usuario_id")
  peso        Decimal   @db.Decimal(5, 2)
  estatura    Decimal?  @db.Decimal(3, 2)
  fecha       DateTime  @db.Date
  notas       String?   @db.Text
  createdAt   DateTime  @default(now()) @map("created_at")

  usuario     Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
  @@index([fecha])
  @@map("progreso")
}

// Tabla de Ejercicios
model Ejercicio {
  id            Int      @id @default(autoincrement())
  nombre        String   @db.VarChar(100)
  grupoMuscular String   @map("grupo_muscular") @db.VarChar(50)
  descripcion   String?  @db.Text

  ejerciciosPlan EjercicioPlan[]

  @@map("ejercicios")
}

// Tabla de Planes de Entrenamiento
model PlanEntrenamiento {
  id              Int      @id @default(autoincrement())
  nombre          String   @db.VarChar(100)
  nivel           String   @db.VarChar(50)
  duracionSemanas Int      @map("duracion_semanas")

  ejerciciosPlan EjercicioPlan[]

  @@map("planes_entrenamiento")
}

// Tabla de relación muchos a muchos entre Planes y Ejercicios
model EjercicioPlan {
  id          Int  @id @default(autoincrement())
  planId      Int  @map("plan_id")
  ejercicioId Int  @map("ejercicio_id")
  series      Int
  repeticiones Int @map("repeticiones")

  plan      PlanEntrenamiento @relation(fields: [planId], references: [id], onDelete: Cascade)
  ejercicio Ejercicio          @relation(fields: [ejercicioId], references: [id], onDelete: Cascade)

  @@index([planId])
  @@index([ejercicioId])
  @@map("ejercicios_plan")
}

// Tabla de Comidas
model Comida {
  id           Int      @id @default(autoincrement())
  nombre       String   @db.VarChar(100)
  calories     Int
  proteina     Int      @default(0)
  carbohidratos Int     @default(0)
  grasa        Int      @default(0)

  comidasPlan ComidaPlan[]

  @@map("comidas")
}

// Tabla de Planes Nutricionales
model PlanNutricion {
  id       Int      @id @default(autoincrement())
  nombre   String   @db.VarChar(100)
  objetivo String   @map("objetivo") @db.VarChar(50)

  comidasPlan ComidaPlan[]

  @@map("planes_nutricion")
}

// Tabla de relación muchos a muchos entre Planes Nutricionales y Comidas
model ComidaPlan {
  id        Int @id @default(autoincrement())
  planId    Int @map("plan_id")
  comidaId  Int @map("comida_id")

  plan   PlanNutricion @relation(fields: [planId], references: [id], onDelete: Cascade)
  comida Comida        @relation(fields: [comidaId], references: [id], onDelete: Cascade)

  @@index([planId])
  @@index([comidaId])
  @@map("comidas_plan")
}
