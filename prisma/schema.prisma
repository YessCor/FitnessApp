generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Tabla de Ejercicios
model Ejercicio {
  id            Int      @id @default(autoincrement())
  nombre        String   @db.VarChar(100)
  grupoMuscular String   @map("grupo_muscular") @db.VarChar(50)
  descripcion   String?  @db.Text

  ejerciciosPlan EjercicioPlan[]

  @@map("ejercicios")
}

// Tabla de Planes de Entrenamiento
model PlanEntrenamiento {
  id              Int      @id @default(autoincrement())
  nombre          String   @db.VarChar(100)
  nivel           String   @db.VarChar(50)
  duracionSemanas Int      @map("duracion_semanas")

  ejerciciosPlan EjercicioPlan[]

  @@map("planes_entrenamiento")
}

// Tabla de relación muchos a muchos entre Planes y Ejercicios
model EjercicioPlan {
  id          Int  @id @default(autoincrement())
  planId      Int  @map("plan_id")
  ejercicioId Int  @map("ejercicio_id")
  series      Int
  repeticiones Int @map("repeticiones")

  plan      PlanEntrenamiento @relation(fields: [planId], references: [id], onDelete: Cascade)
  ejercicio Ejercicio          @relation(fields: [ejercicioId], references: [id], onDelete: Cascade)

  @@index([planId])
  @@index([ejercicioId])
  @@map("ejercicios_plan")
}

// Tabla de Comidas
model Comida {
  id           Int      @id @default(autoincrement())
  nombre       String   @db.VarChar(100)
  calories     Int
  proteina     Int      @default(0)
  carbohidratos Int     @default(0)
  grasa        Int      @default(0)

  comidasPlan ComidaPlan[]

  @@map("comidas")
}

// Tabla de Planes Nutricionales
model PlanNutricion {
  id       Int      @id @default(autoincrement())
  nombre   String   @db.VarChar(100)
  objetivo String   @map("objetivo") @db.VarChar(50)

  comidasPlan ComidaPlan[]

  @@map("planes_nutricion")
}

// Tabla de relación muchos a muchos entre Planes Nutricionales y Comidas
model ComidaPlan {
  id        Int @id @default(autoincrement())
  planId    Int @map("plan_id")
  comidaId  Int @map("comida_id")

  plan   PlanNutricion @relation(fields: [planId], references: [id], onDelete: Cascade)
  comida Comida        @relation(fields: [comidaId], references: [id], onDelete: Cascade)

  @@index([planId])
  @@index([comidaId])
  @@map("comidas_plan")
}

// Tabla de Progreso
model Progreso {
  id     Int      @id @default(autoincrement())
  fecha  DateTime @db.Date
  peso   Decimal  @db.Decimal(5, 2)
  notas  String?  @db.Text

  @@map("progreso")
}
